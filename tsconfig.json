{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@botpress/sdk": ["node_modules/@botpress/sdk/dist"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}